#ifndef SECRETS_H
#define SECRETS_H

/**
 * @brief Credentials, kept out of version control
 *
 * Copy this file to Secrets.h and fill in the real values.
 * Secrets.h is gitignored; this template is not.
 */
namespace Secrets {
    // The network the door opener joins. Changing house means changing only these two.
    constexpr const char* WIFI_SSID = "";
    constexpr const char* WIFI_PASSWORD = "";

    // Firebase Console > Project Settings > Service Accounts > Database secrets.
    // Required for writes - the device cannot acknowledge unlock requests without it.
    constexpr const char* FIREBASE_AUTH_TOKEN = "";
}

#endif
